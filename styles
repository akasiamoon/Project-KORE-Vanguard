html, body {
    height: 100%;
    margin: 0;
    padding: 0;
    background-color: black; /* This ensures if it fails, it fails to black, not white */
}
/* The Somatic Hijack Overlay */
.somatic-filter {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none; /* Allows user to click things underneath */
    z-index: 9999;
    
    /* The 2300K Amber "Safety" Tone */
    background-color: rgba(255, 126, 0, 0.15); 
    
    /* Soften the blow to the eyes */
    backdrop-filter: sepia(0.6) contrast(0.9) brightness(0.8);
    
    /* Smooth transition for when the Hijack is triggered */
    transition: opacity 2s ease-in-out;
    opacity: 0; 
}

.somatic-filter.active {
    opacity: 1;
}
body, html {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    overflow: hidden; /* Keeps the user focused in the room */
    background-color: #000; /* Deep black background for the "Void" */
}

.wayshrine-container {
    background-image: url('./ProjectKore.png') !important; /* The ./ tells it to look in the root */
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    width: 100vw;
    height: 100vh;
    display: block;
}
